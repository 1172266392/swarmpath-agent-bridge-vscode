{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "SwarmPath Agent Bridge",
  "version": "2.0.0",
  "identifier": "com.swarmpath.agent-bridge",
  "build": {
    "frontendDist": "http://localhost:3300"
  },
  "app": {
    "windows": [
      {
        "title": "SwarmPath Agent Bridge",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "visible": false
      }
    ],
    "security": {}

  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "externalBin": ["binaries/swarmpath-server"],
    "resources": [
      "../web/**/*",
      "../knowledge/**/*",
      "sdk-assets/**/*"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
