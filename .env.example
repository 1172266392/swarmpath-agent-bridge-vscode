# Claude Agent Bridge Configuration
# Copy to .env and fill in values

# Required: Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxx

# Optional: Custom API base URL (for proxies)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Server port (default: 3200)
PORT=3200

# Default working directory for Claude sessions
DEFAULT_CWD=/Users/apple/gitCommit/SwarmPathAI

# Default model
DEFAULT_MODEL=claude-sonnet-4-5-20250929

# Default permission mode: default | acceptEdits | bypassPermissions | plan
DEFAULT_PERMISSION_MODE=acceptEdits

# Max concurrent sessions
MAX_SESSIONS=10

# Session idle timeout in minutes
SESSION_IDLE_TIMEOUT=30

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3100,http://localhost:3000,http://localhost:3011
